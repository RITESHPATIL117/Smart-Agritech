# Local dev: leave EMPTY (Vite proxy → http://localhost:5000)
VITE_API_URL=

# Amplify production: leave VITE_API_URL EMPTY (delete the variable in Amplify console)
# API calls use https://your-app.amplifyapp.com/api/... proxied to Elastic Beanstalk.
# Do NOT set http://elasticbeanstalk.com here — browsers block mixed content (HTTPS→HTTP).
